# ---------------- Travel-Time Parameters ----------------
# Settings for generating or using travel-time tables.
# If cal_tt = True, the program recalculates 1-D travel-time tables
# using the specified velocity model. Otherwise, it loads existing
# precomputed tables (ptt.npy, stt.npy).
cal_tt            = True               # Whether to recreate new 1-D travel-time tables
sdepth_max        = 30                 # Maximum source depth (km)
depth_step        = 1                  # Depth increment for sampling (km)
distance_max      = 2.0                # Maximum epicentral distance (°)
distance_step     = 0.01               # Distance increment step (°)
vel_model         = traveltime/mymodel.nd      # Path to 1-D velocity model file
ptt_npy           = traveltime/ptt.npy         # Interpolated P-wave travel-time table
stt_npy           = traveltime/stt.npy         # Interpolated S-wave travel-time table

# ---------------- Sampling Parameters ----------------
# Parameters controlling the iterative sampling process used for event location.
# The number of samples decreases by the factor 'multiple' after each iteration.
# Recommended parameter values can be found in the reference paper.
iteration         = 5                  # Number of Iterations
samples           = 3000               # Number of Samples in the first iteration
multiple          = 0.8                # Reduction factor for samples per iteration
top               = 10                 # Number of tops candidates retained per iteration
quantile          = 0.95               # quantile for narrowing the sampling range
search_lat        = 0.6                # Search range in latitude (°)
search_lon        = 0.6                # Search range in longitude (°)
search_depth      = 20                 # Search range in depth (km)
search_time       = 10                 # Search range in origin time (s)

# When True, the algorithm allows repeated association of nearby events.
# This enables detecting multiple earthquakes that occur in quick succession,
# which is valuable in dense aftershock sequences but slightly increases runtime.
is_repeat         = True               # Allow repeated association for closely timed events

# ---------------- Scoring Parameters ----------------
# Parameters defining how candidate events are evaluated and ranked.
max_distance      = 140                # Maximum allowed epicentral distance for association (km)
number_weight     = 0.95               # Weight assigned to the number-based score
mag_weight        = 0                  # Weight assigned to the magnitude-based score
P_weight          = 0.5                # Weight for P-phase (S-phase weight = 1 - P_weight)

# Method for phase-count-based scoring.
# Controls how the number of associated phases contributes to the final score.
# Options:
#   number           : use the number of associated phases
#   prob_number      : phase count weighted by picking probability
#   number_both      : count P and S phases jointly
#   prob_number_both : count P and S phases jointly and weight by picking probability
number_type       = prob_number_both

# Method for travel-time residual scoring.
# Controls how the travel-time residuals between theoretical and observed arrivals are evaluated.
# Options:
# rms                : residual-based score without additional weighting
# distance_rms       : residuals weighted by station distance
# prob_rms           : residuals weighted by picking probability
# prob_distance_rms  : residuals weighted by both distance and picking probability
time_type         = prob_distance_rms
dis0              = 50                 # Lower threshold for distance weighting (km)
dis1              = 100                # Upper threshold for distance weighting (km)

# ---------------- Travel-Time Tolerances ----------------
# Defines how much observed travel times can deviate from theoretical values.
# If max_tolerance = min_tolerance : a constant tolerance is used.
# If max_tolerance > min_tolerance : tolerance increases linearly with distance.
min_P_tolerance   = 0.3                # Minimum allowable deviation of P-wave travel time (s)
max_P_tolerance   = 0.8                # Maximum allowable deviation of P-wave travel time (s)
min_S_tolerance   = 0.5                # Minimum allowable deviation of S-wave travel time (s)
max_S_tolerance   = 1.0                # Maximum allowable deviation of S-wave travel time (s)

# ---------------- Output Parameters ----------------
# Rules that determine whether an event is accepted and output.
min_p             = 0                  # Minimum number of P phases required
min_s             = 0                  # Minimum number of S phases required
min_both          = 5                  # Minimum number of stations with both P and S phases
min_sum           = 0                  # Minimum total number of phases (P + S)
only_double       = False              # Require both P and S picks at a station; helpful in large study areas or dense seismicity to reduce phase interference

# ---------------- General Parameters ----------------
# General runtime and file control settings.
code              = Test               # Code or short name identifying the study region
logger_dir        = results            # Directory for saving logs and results
pick_dir          = picks              # Directory containing daily pick CSV files
year0             = 2019               # Starting year of data processing
month0            = 7                  # Starting month of data processing
day0              = 4                  # Starting day of data processing
nday              = 1                  # Number of consecutive days to process
device            = cuda               # Computation device ['cuda', 'cpu']

# The maximum number of picks processed per batch.
# Adjust this value according to your system memory and GPU capacity.
max_batch_size    = 500000             # Maximum number of samples processed per batch

# ---------------- Visualization ----------------
# Visualization settings used mainly for debugging or result inspection.
is_plot           = False              # Enable visualization (True/False)
check_P_index     = 3                  # Index of the P-phase to visualize (for debugging)
plot_dir          = Plot               # Directory for saving plot results
